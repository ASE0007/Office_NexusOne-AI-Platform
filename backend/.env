# NexusOne AI - Environment Variables
# Copy this file to .env and fill in your values

# Django
SECRET_KEY=your-super-secret-key-change-this-in-production-min-50-chars
DEBUG=True
ENVIRONMENT=development
ALLOWED_HOSTS=localhost,127.0.0.1

# Error Tracking (optional — leave blank to disable, app works fine without it)
SENTRY_DSN=

# Database (PostgreSQL recommended for production)
# SQLite (development):
DATABASE_URL=sqlite:///nexusone.db
# PostgreSQL (production):
# DATABASE_URL=postgres://user:password@localhost:5432/nexusone_db

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@nexusone.ai

# OpenAI (Required for full AI features — app works with limited fallback responses without it)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# ── The integrations below are OPTIONAL. The app runs fine without them — ──
# ── these features simply stay inactive until you add real credentials.  ──

# Stripe (Payment Gateway) — leave blank to disable card payments
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio (SMS Notifications) — leave blank to disable SMS alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AWS S3 (File Storage) — leave blank to use local disk storage instead
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
